# LLM (optional)
GEMINI_API_KEY=
# Default: gemini-2.5-flash (1.5 / 2.0 often 404 on new keys)
# GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=

# Legal APIs (optional)
KANOON_API_KEY=
COURTLISTENER_API_KEY=

# Salesforce webhook — set same value in SF Named Credential / Flow header
SALESFORCE_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Re-pull open Cases from Salesforce on every API restart (recommended on Render — disk is ephemeral)
# Defaults to ON when SF OAuth vars below are set. Set false to disable.
# SF_SYNC_ON_STARTUP=true
# SF_SYNC_LIMIT=25
# Optional: persistent path if you attach a Render disk (survives restarts without re-sync)
# EXTERNAL_CLAIMS_STORE=/var/data/external_claims_store.json
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REFRESH_TOKEN=
